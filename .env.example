# Domain used by Caddy in production.
# Example: product-enrichment.company.com
# For local Docker development, this value is not used.
APP_DOMAIN=product-enrichment.example.com

# Required for AI enrichment.
# Get a DeepSeek key at https://platform.deepseek.com/
# Do not commit your real .env file.
DEEPSEEK_API_KEY=your_key_here

# Enrichment QA mode:
# - standard: faster/cheaper; uses deterministic validation first and calls AI reviewers only when needed.
# - strict: slower/costlier; adds extra AI review/readiness passes for maximum caution.
QA_MODE=standard
